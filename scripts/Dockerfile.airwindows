FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    pkg-config \
    libasound2-dev \
    libfreetype6-dev \
    libx11-dev \
    libxrandr-dev \
    libxinerama-dev \
    libxcursor-dev \
    libxext-dev \
    libwebkit2gtk-4.0-dev \
    libcurl4-openssl-dev \
    libjack-jackd2-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
