{
  "id": "clap",
  "name": "Airwindows (curated)",
  "abbrev": "AWC",
  "version": "0.1.0",
  "description": "Airwindows effects, filtered via plugins/allowlist.txt (edit it to choose your own subset)",
  "author": "charlesvestal, Chris Johnson (Airwindows); curated fork",
  "license": "MIT",
  "dsp": "clap.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": true,
    "chainable": true,
    "component_type": "audio_fx",
    "chain_params": [
      {
        "key": "plugin_id",
        "name": "Plugin",
        "type": "string"
      }
    ]
  },
  "assets": {
    "path": "plugins",
    "label": "CLAP Plugins",
    "extensions": [
      ".clap"
    ],
    "description": "Upload .clap audio effect plugins (ARM64 Linux)"
  }
}
